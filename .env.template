# =============================================================================
# Configuración del Proyecto: Mapa de Desempleo en Colombia
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno:
#   cp .env.template .env
# =============================================================================

# --- Directorios ---
DATA_DIR=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
GEO_DIR=./data/geo

# --- DANE / Fuentes de datos ---
DANE_BASE_URL=https://www.dane.gov.co/files/operaciones/GEIH/
DANE_HISTORIC_URL=https://www.dane.gov.co/files/investigaciones/boletines/ech/nuevo-enfoque-conceptual-metodologico-2018/anexo-mercado-laboral-segun-proyecciones-CNPV2018.xlsx
DANE_GEOPORTAL_URL=https://geoportal.dane.gov.co/

# --- datos.gov.co (Socrata API) ---
# App Token opcional (sin token = límite 1,000 requests/día)
SOCRATA_APP_TOKEN=
SOCRATA_BASE_URL=https://www.datos.gov.co

# --- Mapbox (opcional - para mapas avanzados con capas satelitales) ---
MAPBOX_TOKEN=

# --- Caché ---
# TTL en segundos (86400 = 24 horas)
CACHE_TTL=86400

# --- Logging ---
LOG_LEVEL=INFO

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
